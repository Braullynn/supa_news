# -----------------------------------------------------------------------------
# SUPA NEWS! - CONFIGURAÇÕES DE AMBIENTE (EXEMPLO)
# -----------------------------------------------------------------------------

# --- GOOGLE AI STUDIO (GEMINI) ---
# Obtenha em: https://aistudio.google.com/
NEXT_PUBLIC_GEMINI_API_KEY=sua_chave_aqui

# --- SUPABASE (BANCO DE DADOS) ---
# Obtenha em: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui

# --- NEWS APIS ---
# GNews API: https://gnews.io/ (100 requests/dia grátis)
GNEWS_API_KEY=sua_chave_aqui

# --- CONFIGURAÇÕES DO BOT ---
# Frequência e Horário (em formato cron se usar Vercel Cron)
# Exemplo: 0 8 * * * (Todo dia às 08:00 AM)
NEWS_SCHEDULE="0 8 * * *"

# --- LOGS E DEBUG ---
# Nível de log: debug, info, error
LOG_LEVEL=debug
# -----------------------------------------------------------------------------
